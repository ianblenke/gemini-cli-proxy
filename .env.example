# Path to .gemini config on the host (contains oauth_creds.json)
GEMINI_CONFIG_PATH=/home/ianblenke/.gemini
# Proxy server port
PORT=8080
# API key to protect the proxy (leave empty to disable auth)
PROXY_API_KEY=
# Google OAuth client credentials (from gemini CLI source code)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Set to 0 to wait for quota reset instead of returning 429
RATE_LIMIT=
